{
  "name": "zhiyu-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @zhiyu/db migrate",
    "seed:all": "pnpm --filter @zhiyu/db seed:all",
    "seed:courses": "pnpm --filter @zhiyu/db seed:courses",
    "seed:from-file": "pnpm --filter @zhiyu/db seed:from-file",
    "seed:discover-china": "pnpm --filter @zhiyu/db seed:discover-china",
    "seed:user": "pnpm --filter @zhiyu/db seed:user",
    "preflight": "node scripts/preflight.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}