{
  "name": "zhiyu",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky || true",
    "db:migrate": "pnpm --filter @zhiyu/api db:migrate",
    "db:check": "pnpm --filter @zhiyu/api db:check",
    "seed": "pnpm --filter @zhiyu/db seed:all",
    "i18n:lint": "pnpm --filter @zhiyu/i18n i18n:lint",
    "i18n:coverage": "pnpm --filter @zhiyu/i18n i18n:coverage"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
