{
  "name": "@zhiyu/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:check": "tsx scripts/db-check.ts"
  },
  "dependencies": {
    "@zhiyu/config": "workspace:*",
    "@zhiyu/db": "workspace:*",
    "@zhiyu/i18n": "workspace:*",
    "@zhiyu/sdk": "workspace:*",
    "bullmq": "^5.7.0",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
