# =====================================================================
# 知语 dev 环境唯一变量模板
# 拷贝为 docker/env/.env.dev 后即可启动；缺失第三方 Key 时对应 adapter 自动 mock。
# =====================================================================

# ---- 基础 ----
APP_ENV=dev
APP_NAME=zhiyu
LOG_LEVEL=debug

# ---- Postgres / Supabase Auth（GoTrue）----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgres://postgres:postgres@supabase-db:5432/postgres

# 与 GoTrue 共享的 JWT 密钥（>=32 字符）
SUPABASE_JWT_SECRET=devdevdevdevdevdevdevdevdevdev01
# GoTrue / PostgREST 通过 JWT 鉴别匿名 / service_role
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InpoaXl1LWRldiIsImV4cCI6MTk5OTk5OTk5OX0.6S0p6tT5FjCm3o0uw5p1rJtbZnMNI1PYx3K-ABcdEFG
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiemhpeXUtZGV2IiwiZXhwIjoxOTk5OTk5OTk5fQ.HoVU6jL_xN7uS7PQrPmVqTkTiGzRAoXtQgZLbvE2k4w

# 后端调用 Supabase 网关（容器内）
SUPABASE_URL=http://supabase-gateway:8000
# 前端浏览器调用 Supabase 网关（host 端口）
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- API 端口 ----
API_APP_PORT=8100
API_ADMIN_PORT=9100
WEB_APP_PORT=3100
WEB_ADMIN_PORT=4100

# 前端调用后端
VITE_API_BASE_APP=http://localhost:8100/api/v1
VITE_API_BASE_ADMIN=http://localhost:9100/admin/v1

# ---- 默认超级管理员（首次部署后立即改密）----
SUPER_ADMIN_EMAIL=admin@zhiyu.local
SUPER_ADMIN_PASSWORD=Admin@123456

# ---- 节流 ----
RATE_LIMIT_RPM=120
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_WINDOW_MIN=15

# ---- 第三方 Key（缺则 mock）----
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LANGSMITH_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

PADDLE_API_KEY=
PADDLE_PUBLIC_KEY=
PADDLE_WEBHOOK_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
RESEND_API_KEY=

# ---- GoTrue 专用（自托管 Supabase Auth）----
GOTRUE_SITE_URL=http://localhost:3100
GOTRUE_URI_ALLOW_LIST=http://localhost:3100,http://localhost:4100
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true     # dev: 自动确认（mock 邮件）；prod 关闭
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_JWT_EXP=3600
GOTRUE_JWT_ADMIN_ROLES=service_role
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
